{% from "govuk/components/table/macro.njk" import govukTable %}

{% macro analyticsTableComponent(tableName, gaContainerId, containerIdPurpose, containerIdExpires) %}
  {% set head = [] %}
  {% for header in tableName.headers %}
    {% set head = head.concat([{
      text: header,
      classes: "app-custom-class"
    }]) %}
  {% endfor %}

  {% set tableRows = [] %}
  {% for row in tableName.rows %}
    {% set tableCell = [] %}
    {% for cell in row %}
      {% set tableCell = tableCell.concat([{
        text: cell
      }]) %}
    {% endfor %}
    
    {% set tableRows = tableRows.concat([tableCell]) %}
  {% endfor %}

  {% if gaContainerId %}
    {% set gaRow = [
      { text: "_ga_" + gaContainerId },
      { text: containerIdPurpose },
      { text: containerIdExpires }
    ] %}

    {% set tableRows = tableRows.concat([gaRow]) %}
  {% endif %}

  {% set args = {
    head: head,
    rows: tableRows
  } %}

  {{ govukTable(args) }}
{% endmacro %}
